<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">

    <title>Cocos Creator | <%= projectName %></title>

    <meta name="viewport" content="width=device-width,user-scalable=no,initial-scale=1,minimum-scale=1,maximum-scale=1,minimal-ui=true"/>
    <meta name="apple-mobile-web-app-capable" content="yes"/>
    <meta name="mobile-web-app-capable" content="yes"/>
    <meta name="full-screen" content="yes"/>
    <meta name="screen-orientation" content="portrait"/>
    <meta name="x5-fullscreen" content="true"/>
    <meta name="360-fullscreen" content="true"/>

    <meta name="renderer" content="webkit"/>
    <meta name="force-rendering" content="webkit"/>
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1"/>

    <link rel="stylesheet" type="text/css" href="<%= cssUrl %>"/>
    <link rel="icon" href="favicon.ico"/>
    <style>
      html,
      body {
        width: 100%;
        height: 100%;
        overflow: hidden;
      }

      #GameDiv {
        width: min(calc(100vw - 20px), calc(56.2219vh - 44.9775px), 750px) !important;
        height: min(calc(100vh - 80px), calc(177.8667vw - 35.5733px), 1334px) !important;
        aspect-ratio: 750 / 1334;
        overflow: hidden;
      }
    </style>
  </head>
  <body>
    <h1 class="header"><%= projectName %></h1>

    <div id="GameDiv" cc_exact_fit_screen="true">
      <div id="Cocos3dGameContainer">
        <canvas id="GameCanvas" width="750" height="1334" tabindex="99"></canvas>
      </div>
    </div>
    <p class="footer">
      Created with <a href="https://www.cocos.com/products" title="Cocos Creator">Cocos Creator</a>
    </p>
    <%- include(cocosTemplate, {}) %>
  </body>
</html>
